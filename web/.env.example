# Supabase (criar projeto em https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# Usa a chave "anon" em formato JWT (começa por eyJ...). O Realtime/chat por WebSocket
# pode falhar com a chave publishable (sb_publishable_...) — ver API Settings no dashboard.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role — só servidor (webhook Stripe, jobs). Nunca expor no cliente.
SUPABASE_SERVICE_ROLE_KEY=

# URL pública da app (redirects Stripe). Na Vercel podes usar só VERCEL_URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=
# Webhook signing secret (Developers → Webhooks → endpoint)
STRIPE_WEBHOOK_SECRET=

# Opcional: Stripe publishable (futuros elementos no browser)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Opcional: logs detalhados de upload na consola do browser (criar anúncio)
# NEXT_PUBLIC_DEBUG_UPLOAD=true
